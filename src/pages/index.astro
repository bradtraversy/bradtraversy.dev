---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Latest article (most recent non-draft)
const articles = await getCollection('articles', ({ data }) => !data.draft);
const latestArticle = articles
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())[0];

// Recent devlog (3 most recent non-draft)
const devlogEntries = await getCollection('devlog', ({ data }) => !data.draft);
const recentDevlog = devlogEntries
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

// Currently building — featured projects (with sensible fallback to active status)
const ACTIVE_STATUSES = ['alpha', 'beta', 'live'];
const allProjects = await getCollection('projects');
const currentlyBuilding = allProjects
  .filter(
    (p) => p.data.featured || ACTIVE_STATUSES.includes(p.data.status),
  )
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
  })
  .slice(0, 4);

// Latest tools strip (5 newest, non-archived)
const allTools = await getCollection('tools');
const latestTools = allTools
  .filter((t) => !t.data.archived)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);

const fmtDate = (d: Date) => d.toISOString().slice(0, 10);
---

<BaseLayout
  title="travx labs — articles, devlog, projects, and the tools i ship"
  pageTitle="home.md"
  currentSection="home"
>
  <!-- HERO -->
  <section class="section">
    <h1 class="h1"><span class="hash"># </span>travx labs</h1>
    <p class="lede">
      a public lab — articles, devlog, projects, and the tools i ship. built by{' '}
      <a href="/about" class="link">brad traversy</a>.
    </p>
  </section>

  <!-- CURRENTLY BUILDING (projects) -->
  {
    currentlyBuilding.length > 0 && (
      <section class="section">
        <h2 class="h2"><span class="hash">## </span>currently building</h2>
        <div class="comment">
          // see <a href="/now" class="link">/now</a> for full status
        </div>
        <div class="card-grid">
          {currentlyBuilding.map((project) => (
            <a class="card" href={`/projects/${project.id}`}>
              <div class="card-title">{project.data.name}</div>
              <div class="card-status">
                <span class:list={['pill', project.data.status]}>{project.data.status}</span>
              </div>
              <div class="card-meta">{project.data.tagline}</div>
            </a>
          ))}
        </div>
        <a href="/projects" class="link more-link">→ all projects</a>
      </section>
    )
  }

  <!-- LATEST ARTICLE -->
  {
    latestArticle && (
      <section class="section">
        <h2 class="h2">
          <span class="hash">## </span>latest article
        </h2>
        <div class="article-hero">
          <div class="meta">
            {fmtDate(latestArticle.data.publishDate)}
            {latestArticle.data.tags.length > 0 && (
              <span class="tags">
                {latestArticle.data.tags.map((t) => `#${t}`).join(' ')}
              </span>
            )}
          </div>
          <a class="title" href={`/articles/${latestArticle.id}`}>
            {latestArticle.data.title}
          </a>
          <div class="dek">{latestArticle.data.dek}</div>
          <div class="read">
            <a href={`/articles/${latestArticle.id}`} class="link">
              read article →
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- RECENT DEVLOG -->
  {
    recentDevlog.length > 0 && (
      <section class="section">
        <h2 class="h2">
          <span class="hash">## </span>recent devlog
        </h2>
        <div class="comment">// pulled from /devlog — most recent first</div>
        <div>
          {recentDevlog.map((entry) => (
            <div class="devlog-row">
              <span class="date">{fmtDate(entry.data.publishDate)}</span>
              <a class="title" href={`/devlog/${entry.id}`}>
                {entry.data.title}
              </a>
              {entry.data.project && <span class="tag">#{entry.data.project}</span>}
            </div>
          ))}
        </div>
        <a href="/devlog" class="link more-link">
          → all devlog entries
        </a>
      </section>
    )
  }

  <!-- LATEST TOOLS -->
  {
    latestTools.length > 0 && (
      <section class="section">
        <h2 class="h2">
          <span class="hash">## </span>latest tools
        </h2>
        <div class="comment">
          // small one-day utilities — each gets its own page
        </div>
        <div>
          {latestTools.map((tool) => (
            <div class="tools-row">
              <a class="name" href={`/tools/${tool.id}`}>
                {tool.data.name}
              </a>
              <div class="desc">{tool.data.tagline}</div>
              <div class="status-cell">
                <span class:list={['pill', tool.data.free ? 'free' : 'paid']}>
                  {tool.data.free ? 'free' : 'paid'}
                </span>
              </div>
            </div>
          ))}
        </div>
        <a href="/tools" class="link more-link">→ all tools</a>
      </section>
    )
  }

  <!-- SUBSCRIBE -->
  <section class="section">
    <h2 class="h2"><span class="hash">## </span>subscribe</h2>
    <div class="comment">
      // weekly digest — articles, devlog highlights, what shipped. zero filler.
    </div>
    <form class="subscribe-row" method="POST" action="/api/subscribe">
      <input type="email" name="email" placeholder="you@example.com" required />
      <button type="submit">subscribe</button>
    </form>
  </section>

  <div class="comment" style="margin-top: 24px;">
    // EOF home.md<span class="cursor"></span>
  </div>
</BaseLayout>
