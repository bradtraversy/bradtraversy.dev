---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = await getCollection('projects');
const sorted = projects.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const projectCards = sorted.map((project) => ({
  project,
  image: project.data.screenshots?.[0] ?? project.data.heroImage,
  stack: project.data.stack.slice(0, 4),
  extraStackCount: Math.max(project.data.stack.length - 4, 0),
}));
const badgeClass = (badge: string) =>
  badge.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---

<BaseLayout
  title="projects - brad traversy"
  description="major ongoing work: apps, clis, infrastructure. status, stack, and how it's built."
  pageTitle="projects/"
  currentSection="projects"
>
  <section class="section">
    <h1 class="h1"><span class="hash"># </span>projects</h1>
    <p class="lede">
      major ongoing work. each project has its own page with status, stack,
      and a "how it's built" trail of articles and devlog entries.
    </p>
  </section>

  <section class="section">
    {
      projectCards.length === 0 ? (
        <div class="comment">// no projects listed yet</div>
      ) : (
        <div class="projects-grid">
          {projectCards.map(({ project, image, stack, extraStackCount }) => (
            <a class="project-card" href={`/projects/${project.id}`}>
              <div class="project-media">
                {image ? (
                  <Image
                    class="project-card-image"
                    src={image}
                    alt={`${project.data.name} screenshot`}
                    loading="lazy"
                  />
                ) : (
                  <div class="project-card-placeholder">{project.data.name}</div>
                )}
              </div>
              <div class="project-body">
                <div class="project-topline">
                  <div class="project-title">{project.data.name}</div>
                  <div class="project-pills">
                    <span class:list={['pill', project.data.status]}>{project.data.status}</span>
                    {project.data.badge && (
                      <span class:list={['pill', badgeClass(project.data.badge)]}>
                        {project.data.badge}
                      </span>
                    )}
                  </div>
                </div>
                <p class="project-tagline">{project.data.tagline}</p>
                <div class="project-stack">
                  {stack.map((item) => (
                    <span>{item}</span>
                  ))}
                  {extraStackCount > 0 && <span>+{extraStackCount}</span>}
                </div>
                <div class="project-footer">
                  <span>view project</span>
                  <span aria-hidden="true">-&gt;</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </section>

  <div class="comment" style="margin-top: 24px;">
    // EOF projects/<span class="cursor"></span>
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 18px;
    margin: 0;
  }

  .project-card {
    display: flex;
    min-width: 0;
    min-height: 100%;
    flex-direction: column;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    background: linear-gradient(180deg, var(--bg-2) 0%, var(--bg-1) 100%);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.18);
    transition:
      border-color 0.15s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }

  .project-card:hover {
    transform: translateY(-2px);
    border-color: rgba(224, 175, 104, 0.58);
    box-shadow: 0 22px 56px rgba(0, 0, 0, 0.24);
  }

  .project-media {
    aspect-ratio: 16 / 9;
    padding: 10px;
    background:
      linear-gradient(135deg, rgba(122, 162, 247, 0.08), transparent 42%),
      var(--bg-3);
    border-bottom: 1px solid var(--border);
  }

  .project-card-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--bg-2);
  }

  .project-card-placeholder {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    color: var(--fg-comment);
    font-size: 12px;
    border: 1px dashed var(--border-strong);
    border-radius: 5px;
    background: var(--bg-2);
  }

  .project-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
  }

  .project-topline {
    display: flex;
    flex-direction: column;
    gap: 9px;
    align-items: flex-start;
  }

  .project-title {
    min-width: 0;
    color: var(--fg);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.25;
  }

  .project-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: flex-start;
  }

  .project-pills .pill {
    margin-left: 0;
    white-space: nowrap;
  }

  .project-tagline {
    min-height: 44px;
    margin: 0;
    color: var(--fg-comment);
    font-size: 12.5px;
    line-height: 1.65;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .project-stack span {
    display: inline-flex;
    min-height: 24px;
    align-items: center;
    padding: 2px 8px;
    color: var(--fg-muted);
    font-size: 10.5px;
    line-height: 1;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: rgba(36, 40, 59, 0.72);
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
    padding-top: 12px;
    color: var(--accent);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-top: 1px solid var(--border);
  }

</style>
