---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recentArticles = allArticles
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const allDevlog = await getCollection('devlog', ({ data }) => !data.draft);
const recentDevlog = allDevlog
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="subscribed — brad traversy"
  description="you're on the list. weekly digest from bradtraversy.dev."
  pageTitle="subscribed.md"
  currentSection="subscribed"
>
  <section class="section">
    <h1 class="h1"><span class="hash"># </span>you're in</h1>
    <p class="lede">
      thanks for subscribing. the next issue ships on sunday — a short
      digest of what shipped during the week, the new articles and devlog
      entries, and whatever else is worth surfacing.
    </p>
    <p>
      no upsells. no filler. unsubscribe link is at the bottom of every
      email if you change your mind.
    </p>
  </section>

  {recentArticles.length > 0 && (
    <section class="section">
      <h2 class="h2"><span class="hash">## </span>while you're here — recent articles</h2>
      <ul class="post-list">
        {recentArticles.map((a) => (
          <li>
            <a class="link" href={`/articles/${a.id}`}>{a.data.title}</a>
            {a.data.dek && <span class="dek"> — {a.data.dek}</span>}
          </li>
        ))}
      </ul>
      <a href="/articles" class="link more-link">→ all articles</a>
    </section>
  )}

  {recentDevlog.length > 0 && (
    <section class="section">
      <h2 class="h2"><span class="hash">## </span>recent devlog</h2>
      <ul class="post-list">
        {recentDevlog.map((d) => (
          <li>
            <a class="link" href={`/devlog/${d.id}`}>{d.data.title}</a>
          </li>
        ))}
      </ul>
      <a href="/devlog" class="link more-link">→ full devlog stream</a>
    </section>
  )}

  <section class="section">
    <h2 class="h2"><span class="hash">## </span>also worth a look</h2>
    <ul class="prose-list">
      <li><a class="link" href="/projects">projects</a> — the major work, with status and stack on each page</li>
      <li><a class="link" href="/tools">tools</a> — small finished utilities</li>
      <li><a class="link" href="/now">now</a> — what i'm focused on this week</li>
      <li><a class="link" href="/github">github</a> — top repos, recent activity, contribution graph</li>
    </ul>
  </section>

  <div class="comment" style="margin-top: 24px;">
    // EOF subscribed.md<span class="cursor"></span>
  </div>
</BaseLayout>

<style>
  .post-list {
    margin: 12px 0 12px;
    padding-left: 20px;
    list-style: disc;
    color: var(--fg-1);
  }
  .post-list li {
    margin-bottom: 8px;
    line-height: 1.55;
  }
  .post-list .dek {
    color: var(--fg-muted);
  }
  .prose-list {
    margin: 12px 0 16px;
    padding-left: 20px;
    list-style: disc;
    color: var(--fg-1);
  }
  .prose-list li {
    margin-bottom: 8px;
    line-height: 1.55;
  }
  .more-link {
    display: inline-block;
    margin-top: 4px;
    font-size: 13px;
  }
</style>
