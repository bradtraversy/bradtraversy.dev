---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.name} — travx labs`}
  description={entry.data.tagline}
  pageTitle={`${entry.id}.mdx`}
  currentSection="tools"
>
  <section class="section">
    <div class="comment">
      {entry.data.category} · {entry.data.pricing}
    </div>
    <h1 class="h1"><span class="hash"># </span>{entry.data.name}</h1>
    <p class="lede">{entry.data.tagline}</p>

    <div style="margin-top: 18px;">
      <span class:list={['pill', entry.data.status]}>{entry.data.status}</span>
      <span class:list={['pill', entry.data.pricing]}>{entry.data.pricing}</span>
    </div>

    <div style="margin-top: 18px; display: flex; gap: 18px; font-size: 12.5px;">
      {entry.data.url && <a href={entry.data.url} class="link">→ visit</a>}
      {entry.data.repoUrl && <a href={entry.data.repoUrl} class="link">→ repo</a>}
      {entry.data.pricingUrl && <a href={entry.data.pricingUrl} class="link">→ pricing</a>}
    </div>
  </section>

  <article class="section prose-lab">
    <Content />
  </article>

  <div class="comment" style="margin-top: 24px;">
    // EOF {entry.id}.mdx<span class="cursor"></span>
  </div>
</BaseLayout>
