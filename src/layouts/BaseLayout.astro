---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

type Section = 'home' | 'articles' | 'devlog' | 'projects' | 'tools' | 'now' | 'about';

interface Props {
  title: string;
  description?: string;
  pageTitle: string;
  currentSection: Section;
}

const {
  title,
  description = 'a public lab — articles, devlog, and the tools i ship.',
  pageTitle,
  currentSection,
} = Astro.props;

// Build a small explorer tree from real content. Most-recent-first; skips drafts.
const allDevlog = await getCollection('devlog', ({ data }) => !data.draft || import.meta.env.DEV);
const recentDevlog = allDevlog
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 8);

const allProjects = await getCollection('projects');
const recentProjects = allProjects
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);

const allTools = await getCollection('tools');
const recentTools = allTools
  .filter((t) => !t.data.archived)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);

const navItems: Array<{ label: string; href: string; section: Section }> = [
  { label: 'projects', href: '/projects', section: 'projects' },
  { label: 'tools', href: '/tools', section: 'tools' },
  { label: 'devlog', href: '/devlog', section: 'devlog' },
  { label: 'articles', href: '/articles', section: 'articles' },
  { label: 'now', href: '/now', section: 'now' },
  { label: 'about', href: '/about', section: 'about' },
];

const tabs: Array<{ label: string; href: string; section: Section; kind: 'md' | 'folder' }> = [
  { label: 'home.md', href: '/', section: 'home', kind: 'md' },
  { label: 'projects/', href: '/projects', section: 'projects', kind: 'folder' },
  { label: 'tools/', href: '/tools', section: 'tools', kind: 'folder' },
  { label: 'devlog/', href: '/devlog', section: 'devlog', kind: 'folder' },
  { label: 'articles/', href: '/articles', section: 'articles', kind: 'folder' },
  { label: 'now.md', href: '/now', section: 'now', kind: 'md' },
  { label: 'about.md', href: '/about', section: 'about', kind: 'md' },
];

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="brad traversy" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <style is:inline>
      /* Anti-FOUC: keep the body hidden until global.css has applied.
         In Vite dev mode, CSS is injected via JS modules so there's a tick
         where the unstyled .body (no grid) lets all chrome elements stack
         vertically before styles snap them into place. global.css contains
         a matching `body { visibility: visible }` rule that wins as soon
         as the stylesheet is in. The dark html background prevents any
         white flash during the gap. */
      html { background: #16161e; }
      body { visibility: hidden; }
    </style>
  </head>

  <body>
    <div class="window">
      <!-- TITLE BAR -->
      <div class="titlebar">
        <div class="traffic">
          <span class="red"></span>
          <span class="yellow"></span>
          <span class="green"></span>
        </div>
        <div class="title">
          <span class="accent">bradtraversy.dev</span> &mdash; {pageTitle}
        </div>
        <nav class="menu" aria-label="Primary">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={item.section === currentSection ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
          <span aria-hidden="true">⌘K</span>
        </nav>
      </div>

      <!-- TAB BAR -->
      <div class="tabbar">
        {
          tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={['tab', { active: tab.section === currentSection }]}
            >
              <span class:list={['icon', tab.kind]}>{tab.kind === 'md' ? '●' : '▸'}</span>
              {tab.label}
              {tab.section === currentSection && <span class="close">×</span>}
            </a>
          ))
        }
      </div>

      <!-- BODY -->
      <div class="body">
        <!-- ACTIVITY BAR — always visible. The Explorer icon doubles as the
             nav toggle on mobile (slides the explorer in from the right of
             this bar); on desktop the explorer is permanently inline so the
             icon is just a status indicator. -->
        <div class="activity">
          <button
            class="ico ico-explorer"
            id="explorer-toggle"
            type="button"
            aria-label="Toggle explorer"
            aria-expanded="false"
            aria-controls="explorer"
          >
            <Icon name="lucide:files" />
          </button>
          <div class="ico" title="Search"><Icon name="lucide:search" /></div>
          <a
            class="ico"
            href="https://github.com/bradtraversy/bradtraversy.dev"
            target="_blank"
            rel="noopener noreferrer"
            title="View source on GitHub"
            aria-label="View source on GitHub"
          ><Icon name="lucide:github" /></a>
        </div>

        <!-- Backdrop only shown on mobile when the explorer drawer is open.
             Sits inside .body so it covers only the editor area, not the
             activity bar (the user can still tap the toggle to close). -->
        <div class="explorer-backdrop" id="explorerBackdrop"></div>

        <!-- EXPLORER — inline at desktop, slide-out drawer at ≤1024 -->
        <div class="explorer" id="explorer">
          <h3>Explorer</h3>
          <ul class="tree">
            <li>
              <span class="chev">▾</span>
              <span class="ico-folder">▸</span>
              &nbsp;BRADTRAVERSY
            </li>
            <li class:list={['indent-2', { active: currentSection === 'home' }]}>
              <a href="/">
                <span class="chev"></span>
                <span class="ico-md">●</span>
                &nbsp;home.md
              </a>
            </li>
            <li class:list={['indent-2', { active: currentSection === 'projects' }]}>
              <a href="/projects">
                <span class="chev">▾</span>
                <span class="ico-folder">▸</span>
                &nbsp;projects
              </a>
            </li>
            {
              recentProjects.map((project) => (
                <li class="indent-3">
                  <a href={`/projects/${project.id}`} title={project.data.name}>
                    <span class="chev"></span>
                    <span class="ico-md">●</span>
                    <span class="name">{project.id}.mdx</span>
                  </a>
                </li>
              ))
            }
            {allProjects.length > recentProjects.length && (
              <li class="indent-3 see-more-row">
                <a href="/projects">
                  <span class="chev"></span>
                  <span class="ico-md">…</span>
                  <span class="name">see all ({allProjects.length})</span>
                </a>
              </li>
            )}
            <li class:list={['indent-2', { active: currentSection === 'tools' }]}>
              <a href="/tools">
                <span class="chev">▾</span>
                <span class="ico-folder">▸</span>
                &nbsp;tools
              </a>
            </li>
            {
              recentTools.map((tool) => (
                <li class="indent-3">
                  <a href={`/tools/${tool.id}`} title={tool.data.name}>
                    <span class="chev"></span>
                    <span class="ico-md">●</span>
                    <span class="name">{tool.id}.mdx</span>
                  </a>
                </li>
              ))
            }
            {allTools.filter((t) => !t.data.archived).length > recentTools.length && (
              <li class="indent-3 see-more-row">
                <a href="/tools">
                  <span class="chev"></span>
                  <span class="ico-md">…</span>
                  <span class="name">see all ({allTools.filter((t) => !t.data.archived).length})</span>
                </a>
              </li>
            )}
            <li class:list={['indent-2', { active: currentSection === 'devlog' }]}>
              <a href="/devlog">
                <span class="chev">▾</span>
                <span class="ico-folder">▸</span>
                &nbsp;devlog
              </a>
            </li>
            {
              recentDevlog.map((entry) => (
                <li class="indent-3">
                  <a href={`/devlog/${entry.id}`} title={entry.data.title}>
                    <span class="chev"></span>
                    <span class="ico-md">●</span>
                    <span class="name">{entry.id.replace(/^\d{4}-/, '')}.md</span>
                  </a>
                </li>
              ))
            }
            {allDevlog.length > recentDevlog.length && (
              <li class="indent-3 see-more-row">
                <a href="/devlog">
                  <span class="chev"></span>
                  <span class="ico-md">…</span>
                  <span class="name">see all ({allDevlog.length})</span>
                </a>
              </li>
            )}
            <li class:list={['indent-2', { active: currentSection === 'articles' }]}>
              <a href="/articles">
                <span class="chev">▸</span>
                <span class="ico-folder">▸</span>
                &nbsp;articles
              </a>
            </li>
            <li class:list={['indent-2', { active: currentSection === 'now' }]}>
              <a href="/now">
                <span class="chev"></span>
                <span class="ico-md">●</span>
                &nbsp;now.md
              </a>
            </li>
            <li class:list={['indent-2', { active: currentSection === 'about' }]}>
              <a href="/about">
                <span class="chev"></span>
                <span class="ico-md">●</span>
                &nbsp;about.md
              </a>
            </li>
            <li class="indent-2">
              <span class="chev"></span>
              <span class="ico-json">{`{}`}</span>
              &nbsp;package.json
            </li>
          </ul>
        </div>

        <!-- EDITOR -->
        <div class="editor">
          <div class="gutter" aria-hidden="true">
            {Array.from({ length: 20 }).map((_, i) => <span>{i + 1}</span>)}
          </div>
          <div class="content">
            <slot />
          </div>
        </div>
      </div>

      <!-- STATUS BAR -->
      <div class="statusbar">
        <div class="item branch">main</div>
        <div class="item green">●</div>
        <div class="item">{pageTitle}</div>
        <div class="spacer"></div>
        <div class="item encoding">UTF-8</div>
        <div class="item eol">LF</div>
        <div class="item syntax">Markdown</div>
        <div class="item accent">Ln 1, Col 1</div>
      </div>
    </div>

    <div class="cmdk-hint" aria-hidden="true">
      <kbd>⌘</kbd> <kbd>K</kbd> &nbsp;to navigate
    </div>

    <script>
      // Activity-bar Explorer icon (☰) toggles the explorer at every width.
      // Desktop (>=1025): toggles `body.explorer-hidden` to collapse/restore
      //   the inline panel. Editor expands into the freed grid column.
      // Mobile (<=1024): toggles `body.nav-open` to slide the panel in/out
      //   over the editor with a backdrop. ESC + backdrop tap close it.
      // Each class only takes effect inside its own breakpoint, so the two
      // states never fight. Resize across the boundary clears both classes
      // so the user sees the breakpoint's default state cleanly.
      const toggle = document.getElementById('explorer-toggle');
      const backdrop = document.getElementById('explorerBackdrop');
      const isDesktop = () => window.matchMedia('(min-width: 1025px)').matches;
      const stateClass = () => (isDesktop() ? 'explorer-hidden' : 'nav-open');
      const isExpanded = () =>
        isDesktop()
          ? !document.body.classList.contains('explorer-hidden')
          : document.body.classList.contains('nav-open');

      const sync = () => {
        toggle?.setAttribute('aria-expanded', String(isExpanded()));
      };

      toggle?.addEventListener('click', () => {
        document.body.classList.toggle(stateClass());
        sync();
      });

      // Mobile-only: backdrop tap and ESC close the drawer. (Desktop has no
      // backdrop, and ESC collapsing the panel out from under you would feel
      // jarring — leave it as a deliberate icon click there.)
      const closeMobile = () => {
        if (!isDesktop()) {
          document.body.classList.remove('nav-open');
          sync();
        }
      };
      backdrop?.addEventListener('click', closeMobile);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMobile();
      });

      // Mobile-only: tapping a link inside the drawer closes it for snappiness
      document.querySelectorAll('#explorer a').forEach((a) => {
        a.addEventListener('click', closeMobile);
      });

      // On significant resize, drop both state classes so each breakpoint
      // boots up in its natural default (desktop visible, mobile hidden)
      let lastWidth = window.innerWidth;
      window.addEventListener('resize', () => {
        if (Math.abs(window.innerWidth - lastWidth) > 100) {
          document.body.classList.remove('nav-open', 'explorer-hidden');
          sync();
        }
        lastWidth = window.innerWidth;
      });

      sync();
    </script>
  </body>
</html>
